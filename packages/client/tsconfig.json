{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": ["vite/client"],
    "paths": {
      "@prompt-battle/shared": ["../shared/src"]
    }
  },
  "include": ["src", "../shared/src"]
}
